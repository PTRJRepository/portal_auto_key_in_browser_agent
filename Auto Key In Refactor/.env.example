# Copy this file to .env and fill values after pulling/cloning the project.

# Manual Adjustment API used by the PySide6 desktop app
AUTO_KEY_IN_API_BASE_URL=http://localhost:8002
AUTO_KEY_IN_API_KEY=replace_with_manual_adjustment_api_key

# Runner command used by the desktop app
AUTO_KEY_IN_RUNNER_COMMAND=node runner/dist/cli.js

# Default UI values
AUTO_KEY_IN_DEFAULT_PERIOD_MONTH=4
AUTO_KEY_IN_DEFAULT_PERIOD_YEAR=2026
AUTO_KEY_IN_DEFAULT_DIVISION_CODE=AB1
AUTO_KEY_IN_DEFAULT_RUNNER_MODE=multi_tab_shared_session
AUTO_KEY_IN_DEFAULT_MAX_TABS=5
AUTO_KEY_IN_HEADLESS=false

# Plantware login used by the TypeScript Playwright runner
PLANTWARE_BASE_URL=http://plantwarep3:8001
PLANTWARE_USERNAME=replace_with_plantware_username
PLANTWARE_PASSWORD=replace_with_plantware_password
PLANTWARE_DIVISION=AB1
